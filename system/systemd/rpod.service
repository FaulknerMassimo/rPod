[Unit]
Description=rPod UI application
After=rpod-wheel.service sound.target
Wants=rpod-wheel.service

[Service]
ExecStart=/usr/local/bin/rpod
EnvironmentFile=-/etc/rpod/env
StateDirectory=rpod
Restart=on-failure
RestartSec=1
User=rpod
Group=rpod
SupplementaryGroups=video render input audio

[Install]
WantedBy=multi-user.target
