# Template for a local MPD instance used by `make sim` (docs/PLAN.md §5.4's
# desktop iteration loop). Resolved to tools/sim/.mpd-dev.conf by
# `make mpd-dev-conf` (RPOD_MPD_STATE_DIR / SIM_MUSIC_DIR substituted in) —
# not committed, since it embeds machine-specific absolute paths.
#
# This is a dev-only config for browsing/playback testing against real
# tracks. It is unrelated to the on-device mpd.conf in docs/PLAN.md §6.2
# (ALSA/hifiberry output, no network listener) — this one just needs
# something to play through the dev machine's normal audio.

music_directory    "@SIM_MUSIC_DIR@"
# Without this, MPD only rescans music_directory when told to (an explicit
# `update`, e.g. via `mpc update`) -- newly added tracks otherwise stay
# invisible to every browse/search query indefinitely, with no error to
# signal it. Caught when an album's own tag data was correct on disk but a
# database query still returned only some of its tracks.
auto_update        "yes"
playlist_directory "@RPOD_MPD_STATE_DIR@/playlists"
db_file            "@RPOD_MPD_STATE_DIR@/db"
log_file           "@RPOD_MPD_STATE_DIR@/log"
pid_file           "@RPOD_MPD_STATE_DIR@/pid"
state_file         "@RPOD_MPD_STATE_DIR@/state"
sticker_file       "@RPOD_MPD_STATE_DIR@/sticker.sql"

bind_to_address    "@RPOD_MPD_STATE_DIR@/socket"

audio_output {
    type    "pulse"
    name    "Dev speakers"
}

# Raw PCM tap for the Now Playing visualizer (src/audio/visualizer.c). Format
# is fixed regardless of source file format (this library has 96kHz/24-bit
# FLACs in it) so the visualizer doesn't have to handle more than one PCM
# layout -- must match RPOD_VIS_SAMPLE_RATE/RPOD_VIS_CHANNELS in
# visualizer.h. MPD creates the fifo file itself; nothing to mkfifo by hand.
audio_output {
    type    "fifo"
    name    "Visualizer feed"
    path    "@RPOD_MPD_STATE_DIR@/visualizer.fifo"
    format  "44100:16:2"
}
